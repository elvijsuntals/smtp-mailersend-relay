APP_ENV=production
LOG_LEVEL=info

SMTP_LISTEN_ADDR=:2525
SMTP_DOMAIN=relay.local
SMTP_AUTH_USERNAME=relay-user
SMTP_AUTH_PASSWORD=relay-pass
SMTP_REQUIRE_STARTTLS=true
SMTP_ALLOW_INSECURE_AUTH=false
SMTP_TLS_CERT_FILE=./certs/server.crt
SMTP_TLS_KEY_FILE=./certs/server.key
SMTP_ALLOWED_SENDER_DOMAINS=example.com
SMTP_MAX_MESSAGE_BYTES=8388608
SMTP_MAX_RECIPIENTS=1000
SMTP_MAX_CONNECTIONS=200
SMTP_MAX_CONNECTIONS_PER_IP=20
SMTP_RATE_LIMIT_PER_IP_PER_MIN=600

HTTP_LISTEN_ADDR=:8080

# Docker/Dokploy: published (host) ports. Must be unique per deployment.
# If unset, docker-compose defaults to 2525 and 8080.
SMTP_PUBLISHED_PORT=2525
HTTP_PUBLISHED_PORT=8080

SQLITE_PATH=./data/relay.db
SQLITE_MAX_OPEN_CONNS=1
SQLITE_MAX_IDLE_CONNS=1

DISPATCHER_WORKERS=4
QUEUE_CLAIM_LIMIT=1000
QUEUE_LEASE_TIMEOUT=30s
BATCH_MAX_COUNT=500
BATCH_MAX_BYTES=5242880
BATCH_FLUSH_INTERVAL=250ms
RETRY_MAX_ATTEMPTS=8
REQUEUE_STALE_INTERVAL=30s

MAILERSEND_API_KEY=your_api_key
MAILERSEND_BASE_URL=https://api.mailersend.com/v1
MAILERSEND_TIMEOUT=20s
MAILERSEND_ACCOUNT_PLAN=starter
MAILERSEND_ENABLE_CUSTOM_HEADERS=false
# Optional MailerSend plan overrides:
# MAILERSEND_BULK_API_SUPPORTED=true
# MAILERSEND_CUSTOM_HEADERS_SUPPORTED=false
# MAILERSEND_BULK_API_MAX_MESSAGES_PER_REQUEST=500
# MAILERSEND_BULK_API_MAX_REQUESTS_PER_MIN=10
